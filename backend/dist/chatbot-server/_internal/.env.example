# ============================================
# Local AI Chatbot — Environment Configuration
# ============================================

# ── AI Provider: "groq" (cloud, free) or "ollama" (local)
AI_PROVIDER=groq

# ── Groq Cloud API (FREE - https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
# Best models on Groq (all free):
#   llama3-70b-8192   ← Best quality (recommended)
#   llama3-8b-8192    ← Faster, lighter
#   mixtral-8x7b-32768 ← Great for long conversations
GROQ_MODEL=llama3-70b-8192

# ── Ollama Local (only if AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Confidence Threshold (0-100) — below this triggers support
CONFIDENCE_THRESHOLD=70

# ── Database
DB_TYPE=json
DATABASE_PATH=../data/knowledge_base.json

# ── Server
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# ── Logging
LOG_LEVEL=INFO

# ── Support Contact (shown to users on escalation)
SUPPORT_EMAIL=support@yourcompany.com
SUPPORT_PHONE=1-800-YOUR-NUMBER
